<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Entitlements for the bundled Node runtime + its native addons under the
      macOS hardened runtime (required for notarization). The embedded Node
      sidecar runs V8, which JIT-compiles and maps writable+executable memory;
      without these it crashes at launch on a notarized build. Library
      validation is disabled so Node can load our copied native modules
      (sharp / libvips / onnxruntime) which are signed by us, not Apple.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
