{
  "name": "gg-framework",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}' && pnpm --filter matey lint",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix && pnpm --filter matey lint:fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}' 'Matey/**/*.{ts,tsx,css,html,json,md,yml}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}' 'Matey/**/*.{ts,tsx,css,html,json,md,yml}'",
    "test": "pnpm -r test",
    "prepare": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@electron/get",
      "better-sqlite3",
      "electron",
      "esbuild",
      "onnxruntime-node"
    ],
    "overrides": {
      "global-agent": "^4.1.3",
      "ip-address": "^10.1.1"
    },
    "patchedDependencies": {
      "ink@6.8.0": "patches/ink@6.8.0.patch",
      "ink@7.0.2": "patches/ink@7.0.2.patch"
    }
  }
}
